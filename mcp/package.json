{
  "name": "@datatree/mcp",
  "version": "0.1.0",
  "description": "Datatree MCP server: 30+ tools + 6 hooks exposing the datatree supervisor over stdio JSON-RPC.",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "bin": {
    "datatree-mcp": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "biome": "^0.3.3",
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "author": "Anish Trivedi"
}

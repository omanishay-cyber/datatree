{
  "$schema": "https://claude.ai/claude-code/plugin-marketplace-schema.json",
  "name": "datatree",
  "displayName": "datatree — the AI superbrain",
  "description": "Persistent per-project memory that survives context compaction. 27-layer SQLite shard, 33+ MCP tools, 14 visualization views, drift detector, compaction-resilient Step Ledger. 100% local.",
  "version": "0.1.0",
  "author": "Anish Trivedi",
  "homepage": "https://omanishay-cyber.github.io/datatree/",
  "repository": "https://github.com/omanishay-cyber/datatree",
  "license": "Datatree Community License v1.0",
  "plugins": [
    {
      "name": "datatree",
      "version": "0.1.0",
      "description": "AI superbrain MCP — persistent memory, blast-radius queries, drift detection, Step Ledger that survives compaction.",
      "source": {
        "type": "github",
        "repository": "omanishay-cyber/datatree",
        "ref": "main",
        "path": "plugin"
      },
      "manifest": "plugin/plugin.json",
      "lifecycle": {
        "preInstall": "scripts/preinstall.js",
        "postInstall": "scripts/postinstall.js",
        "preUninstall": "scripts/preuninstall.js"
      },
      "supports": {
        "platforms": ["win32", "darwin", "linux"],
        "claudeCode": ">=0.1.0",
        "node": ">=20",
        "rust": ">=1.78"
      },
      "categories": ["context", "memory", "code-graph", "multimodal", "productivity"],
      "keywords": [
        "mcp",
        "claude-code",
        "ai-superbrain",
        "persistent-memory",
        "code-graph",
        "blast-radius",
        "tree-sitter",
        "compaction-resilient",
        "drift-detector",
        "local-first",
        "step-ledger",
        "multimodal"
      ]
    }
  ]
}

{
  "$comment": "datatree-marker v1.0 — merged into .opencode.json. Existing keys preserved.",
  "mcpServers": {
    "datatree": {
      "command": "bun",
      "args": ["{{datatree_root}}/mcp/index.ts"],
      "type": "stdio",
      "env": {
        "DATATREE_HOME": "{{datatree_home}}",
        "DATATREE_PROJECT_ROOT": "{{project_root}}"
      }
    }
  },
  "plugins": [
    ".opencode/plugins/datatree.ts"
  ]
}

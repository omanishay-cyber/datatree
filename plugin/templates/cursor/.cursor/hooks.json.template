{
  "$comment": "mneme-marker v1.0 — Cursor hook entries. Merged into existing .cursor/hooks.json; existing entries preserved.",
  "hooks": {
    "sessionStart": [
      {
        "name": "mneme-prime",
        "command": "{{mneme_root}}/scripts/hooks/cursor-session-start.sh",
        "timeout": 2000
      }
    ],
    "afterFileEdit": [
      {
        "name": "mneme-update",
        "command": "{{mneme_root}}/scripts/hooks/cursor-after-edit.sh",
        "args": ["${file}"],
        "timeout": 5000
      }
    ]
  }
}

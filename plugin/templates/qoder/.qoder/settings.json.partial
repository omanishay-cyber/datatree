{
  "$comment": "mneme-marker v1.0 — merged into .qoder/settings.json. Existing keys preserved.",
  "agent": {
    "rulesFile": "QODER.md",
    "graphFirst": true
  },
  "context": {
    "providers": {
      "mneme": {
        "enabled": true,
        "priority": 100,
        "transport": "mcp",
        "server": "mneme"
      }
    }
  },
  "hooks": {
    "afterEdit": "{{mneme_root}}/scripts/hooks/qoder-after-edit.sh"
  }
}

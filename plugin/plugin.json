{
  "name": "mneme",
  "version": "0.1.0",
  "displayName": "Mneme — The AI Superbrain",
  "description": "Persistent per-project SQLite memory + 14-view live graph + drift detector + 30+ MCP tools. Claude never starts cold, never loses its place.",
  "author": "Anish Trivedi",
  "license": "Apache-2.0",
  "homepage": "https://github.com/omanishay-cyber/mneme",
  "scopes": ["global", "user", "project"],
  "platforms": ["win32", "darwin", "linux"],
  "components": {
    "mcpServers": [
      { "name": "mneme", "config": ".mcp/mneme.json" }
    ],
    "hooks": [
      { "event": "SessionStart", "command": "mneme session-prime" },
      { "event": "UserPromptSubmit", "command": "mneme inject" },
      { "event": "PreToolUse", "command": "mneme pre-tool" },
      { "event": "PostToolUse", "command": "mneme post-tool" },
      { "event": "Stop", "command": "mneme turn-end" },
      { "event": "SessionEnd", "command": "mneme session-end" }
    ],
    "skills": [
      "skills/mneme-query.md",
      "skills/mneme-audit.md",
      "skills/mneme-resume.md"
    ],
    "agents": [
      "agents/mneme-archivist.md",
      "agents/mneme-drift-hunter.md",
      "agents/mneme-blast-tracer.md",
      "agents/mneme-step-verifier.md",
      "agents/mneme-doctor.md",
      "agents/mneme-resumer.md"
    ],
    "commands": [
      { "name": "/mn-view", "command": "mneme view" },
      { "name": "/mn-audit", "command": "mneme audit" },
      { "name": "/mn-recall", "command": "mneme recall" },
      { "name": "/mn-blast", "command": "mneme blast" },
      { "name": "/mn-graphify", "command": "mneme graphify" },
      { "name": "/mn-godnodes", "command": "mneme godnodes" },
      { "name": "/mn-drift", "command": "mneme drift" },
      { "name": "/mn-history", "command": "mneme history" },
      { "name": "/mn-snap", "command": "mneme snap" },
      { "name": "/mn-doctor", "command": "mneme doctor" },
      { "name": "/mn-rebuild", "command": "mneme rebuild" },
      { "name": "/mn-step", "command": "mneme step" }
    ],
    "manifests": {
      "claude": "CLAUDE.md",
      "agents": "AGENTS.md",
      "gemini": "GEMINI.md",
      "qoder": "QODER.md",
      "qwen": "QWEN.md",
      "cursor": ".cursor/rules/mneme.mdc",
      "kiro": ".kiro/steering/mneme.md"
    }
  },
  "install": {
    "preInstall": "scripts/preinstall.js",
    "postInstall": "scripts/postinstall.js",
    "preUninstall": "scripts/preuninstall.js"
  }
}

{
  "name": "mneme-vision",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Vision app for the mneme daemon — 14 view modes + Command Center, served via Bun and packaged via Tauri.",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n vite,api -c blue,green \"bun run dev\" \"bun run serve\"",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "bun server.ts",
    "tauri:dev": "cd tauri && cargo tauri dev",
    "tauri:build": "cd tauri && cargo tauri build",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "deck.gl": "^9.0.0",
    "graphology": "^0.25.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sigma": "^3.0.0",
    "three": "^0.165.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "@biomejs/biome": "^1.8.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.4",
    "@types/three": "^0.165.0",
    "@types/bun": "^1.1.6",
    "bun-types": "^1.1.0",
    "concurrently": "^8.2.2"
  }
}

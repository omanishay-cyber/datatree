# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Mneme runtime data (per-user; never commit)
# Keeps the old `.datatree/` pattern too so orphan dirs from pre-rename installs remain ignored.
~/.mneme/
.mneme/
~/.datatree/
.datatree/

# Models (large; user installs via `mneme models install`)
*.onnx
*.gguf
*.bin
runtime/

# Tauri
src-tauri/target/

# IDE
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary
tmp/
*.tmp
*.swp
*~

# Snapshot output of any indexed project
.code-review-graph/

# Backup files made by mneme's idempotent installer
*.bak

# Generated docs (regenerated from source)
api-docs/

# Local override configs
.env
.env.local
*.local.json

# Google Drive / OneDrive sync junk that sometimes appears
.tmp.driveupload/
.tmp.drive*
.~*
desktop.ini
Thumbs.db

